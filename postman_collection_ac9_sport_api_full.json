            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"macros/1234/asset.jpg\",\n  \"content_type\": \"image/jpeg\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/presign",
              "host": ["{{baseUrl}}"],
              "path": ["presign"]
            }
