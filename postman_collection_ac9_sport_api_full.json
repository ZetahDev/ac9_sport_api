{
  "info": {
    "name": "ac9_sport_api - Full API",
    "description": "Full Postman collection with auth and CRUD for categories, subcategories and products.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "categoryId", "value": "", "type": "string" },
    { "key": "subcategoryId", "value": "", "type": "string" },
    { "key": "productId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"pwd123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"pwd123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "if (json && json.access_token) { pm.environment.set('token', json.access_token); pm.test('saved token', function(){ pm.expect(json.access_token).to.be.a('string'); }); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('contains email', function(){ pm.expect(body).to.have.property('email'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"]
            }
          }
        }
      ]
    },
    {
      "name": "Create category",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"New Category\",\n  \"description\": \"desc\",\n  \"macroCategoryId\": null\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/categories",
          "host": ["{{baseUrl}}"],
          "path": ["categories"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json(); if (json && json.id) pm.environment.set('categoryId', json.id);",
              "pm.test('created', function(){ pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get category",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/categories/{{categoryId}}",
          "host": ["{{baseUrl}}"],
          "path": ["categories", "{{categoryId}}"]
        }
      }
    },
    {
      "name": "Update category",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated Category\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/categories/{{categoryId}}",
          "host": ["{{baseUrl}}"],
          "path": ["categories", "{{categoryId}}"]
        }
      }
    },
    {
      "name": "Delete category",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/categories/{{categoryId}}",
          "host": ["{{baseUrl}}"],
          "path": ["categories", "{{categoryId}}"]
        }
      }
    },
    {
      "name": "Subcategories",
      "item": [
        {
          "name": "List subcategories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/subcategories",
              "host": ["{{baseUrl}}"],
              "path": ["subcategories"]
            }
          }
        },
        {
          "name": "Create subcategory",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Sub\",\n  \"description\": \"desc\",\n  \"categoryId\": \"{{categoryId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/subcategories",
              "host": ["{{baseUrl}}"],
              "path": ["subcategories"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json(); if (json && json.id) pm.environment.set('subcategoryId', json.id);",
                  "pm.test('created', function(){ pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get subcategory",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/subcategories/{{subcategoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["subcategories", "{{subcategoryId}}"]
            }
          }
        },
        {
          "name": "Update subcategory",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Sub\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/subcategories/{{subcategoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["subcategories", "{{subcategoryId}}"]
            }
          }
        },
        {
          "name": "Delete subcategory",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/subcategories/{{subcategoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["subcategories", "{{subcategoryId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Create product (multipart/form-data)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Prod 1", "type": "text" },
                { "key": "description", "value": "A product", "type": "text" },
                { "key": "price", "value": "19.99", "type": "text" },
                { "key": "sizes", "value": "[\"38\",\"39\"]", "type": "text" },
                { "key": "colors", "value": "[\"black\"]", "type": "text" },
                {
                  "key": "category_ids",
                  "value": "[\"{{categoryId}}\"]",
                  "type": "text"
                },
                { "key": "images_base64", "value": "", "type": "text" },
                { "key": "images_files", "type": "file" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json(); if (json && json.id) pm.environment.set('productId', json.id);",
                  "pm.test('created', function(){ pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get product",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Product\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Delete product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          }
        }
      ]
    }
  ]
}
