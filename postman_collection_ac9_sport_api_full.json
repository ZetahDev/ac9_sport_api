              "raw": "{{baseUrl}}/macro-categories/{{macroId}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["macro-categories", "{{macroId}}", "categories"]
            }
          }
        },
        {
          "name": "Upload macro image",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
