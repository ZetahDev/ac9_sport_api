          "name": "Macro image GET presigned URL",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/macro-categories/{{macroId}}/image-url",
              "host": ["{{baseUrl}}"],
              "path": ["macro-categories", "{{macroId}}", "image-url"]
            }
          }
        }
      ]
    },
